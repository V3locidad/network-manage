# Reverse proxy TLS pour la gestion des switchs.
# Certificat auto-signé explicite (certs/), servi quelle que soit l'IP/SNI
# — nécessaire pour un accès par adresse IP (les clients n'envoient pas de SNI).
{
	auto_https off
}

# Interface web (HTTPS) — la webui gère son propre login.
:443 {
	tls /certs/cert.pem /certs/key.pem
	encode gzip
	reverse_proxy webui:8080
}

# Terminal WebSSH (HTTPS). Protégé par le MÊME login que l'interface :
# Caddy interroge la webui (/_authcheck) ; accès refusé si pas connecté.
:8443 {
	tls /certs/cert.pem /certs/key.pem
	forward_auth webui:8080 {
		uri /_authcheck
	}
	reverse_proxy webssh:8888
}
