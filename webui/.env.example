# Copie en .env (ignoré par git) et renseigne les valeurs.
#  - WEBUI_PASSWORD : mot de passe d'accès à l'interface (partagé techniciens)
#  - WEBUI_SECRET   : clé de session Flask, valeur aléatoire
#       génère-la avec :  head -c32 /dev/urandom | base64
WEBUI_PASSWORD=change_me
WEBUI_SECRET=change_me_random

# IP du serveur TFTP qui sert les images firmware = le LXC lui-même, sur le
# réseau de management des switchs (utilisé par l'action « Mise à jour firmware »).
TFTP_SERVER=10.0.0.50

# Mot de passe Ansible Vault servant à chiffrer secret/switch_creds.yml.
# Laisse vide tant que le fichier n'est pas chiffré. Pour activer le chiffrement :
#   1) mets ici un mot de passe vault    2) ./secret/vault.sh encrypt
ANSIBLE_VAULT_PASSWORD=
